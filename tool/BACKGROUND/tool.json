{
  "name": "BACKGROUND",
  "version": "1.0.0",
  "description": "Run and manage background processes.",
  "purpose": "Allow non-blocking execution of time-consuming tasks with logging and monitoring.",
  "dependencies": [
    "PYTHON"
  ],
  "pip_dependencies": [
    "psutil"
  ],
  "usage": [
    "BACKGROUND run <command>",
    "BACKGROUND list",
    "BACKGROUND stop <pid>",
    "BACKGROUND wait <pid>",
    "BACKGROUND cleanup"
  ]
}

