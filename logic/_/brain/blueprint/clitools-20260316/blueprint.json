{
  "name": "clitools-20260316",
  "version": "1.1",
  "inherits": "base",
  "description": "File-based brain with three tiers and BRAIN CLI integration. The project default — zero external dependencies, full ecosystem integration.",
  "sessions": {
    "enabled": true,
    "manifest_file": "MANIFEST.md"
  },
  "commands": {
    "audit": {
      "description": "Full code quality + imports audit",
      "run": "TOOL --audit code && TOOL --audit imports"
    },
    "reflect": {
      "description": "Self-check protocol + system gap review",
      "run": "BRAIN reflect"
    },
    "improve": {
      "description": "Generate improvement suggestions from lessons",
      "run": "SKILLS suggest"
    },
    "digest": {
      "description": "Check lessons for distillation opportunities",
      "run": "BRAIN digest"
    },
    "status": {
      "description": "Brain dashboard + ecosystem overview",
      "run": "BRAIN status && TOOL eco"
    },
    "test": {
      "description": "Run all root-level tests",
      "run": "TOOL --test root"
    },
    "sanity": {
      "description": "Sanity-check all installed tools",
      "run": "TOOL --dev audit-bin && TOOL --audit quality"
    }
  },
  "tiers": {
    "working": {
      "description": "Hot state: current session tasks, context, recent activity.",
      "backend": "flatfile",
      "relative_path": "working/",
      "files": {
        "context": "context.md",
        "tasks": "tasks.json",
        "activity": "activity.jsonl"
      },
      "lifecycle": "session",
      "inject_at": "sessionStart"
    },
    "knowledge": {
      "description": "Persistent knowledge: lessons, skills, institutional memory.",
      "backend": "flatfile",
      "relative_path": "knowledge/",
      "files": {
        "lessons": "lessons.jsonl",
        "suggestions": "suggestions.jsonl",
        "evolution": "evolution.jsonl"
      },
      "lifecycle": "permanent",
      "inject_at": "on_demand"
    },
    "episodic": {
      "description": "Long-term personality and accumulated memory.",
      "backend": "flatfile",
      "relative_path": "episodic/",
      "files": {
        "soul": "SOUL.md",
        "memory": "MEMORY.md",
        "daily": "daily/"
      },
      "lifecycle": "permanent",
      "inject_at": "sessionStart"
    }
  }
}
