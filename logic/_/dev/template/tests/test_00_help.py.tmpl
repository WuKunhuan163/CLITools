import unittest
import subprocess
import sys
from pathlib import Path


class TestHelp(unittest.TestCase):
    def test_help(self):
        """Tool supports --help and returns exit code 0."""
        project_root = Path(__file__).resolve().parent.parent.parent.parent
        bin_path = project_root / "bin" / "{short_name}" / "{short_name}"
        if not bin_path.exists():
            bin_path = project_root / "tool" / "{name}" / "main.py"

        cmd = [sys.executable, str(bin_path), "--help"]
        res = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
        self.assertEqual(
            res.returncode, 0,
            f"--help failed (code {{res.returncode}}): {{res.stderr[:200]}}",
        )


if __name__ == "__main__":
    unittest.main()
