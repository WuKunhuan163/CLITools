{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "python3 logic/_/hooks/IDE/Cursor/brain_inject.py"
      }
    ],
    "postToolUse": [
      {
        "command": "python3 logic/_/hooks/IDE/Cursor/file_search_fallback.py"
      }
    ],
    "afterShellExecution": [
      {
        "command": "python3 logic/_/hooks/IDE/Cursor/userinput_flag.py",
        "matcher": "USERINPUT"
      }
    ]
  }
}
