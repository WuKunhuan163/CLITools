#!/usr/bin/env python3
"""{name} tool — entry point.

Minimal main.py: inherits ToolBase, delegates to stateless argparse router.
The base discovers commands by traversing logic/_/ (eco) and tool logic/ (hierarchical).
All application logic lives in logic/**/cli.py endpoints, not here.
"""
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent.parent))

from interface.tool import ToolBase

tool = ToolBase("{name}")
if tool.handle_command_line():
    sys.exit(0)
