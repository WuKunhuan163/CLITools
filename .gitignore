# Ignore everything by default
/*

# Core framework files
!/main.py
!/setup.py
!/tool.json
!/README.md
!/.gitignore
!/.gitattributes

# Core framework directories
!/logic/
!/bin/
!/test/
!/tool/

# Within tools, track the code but ignore transient data/logs
!/tool/*/
/tool/*/data/
/tool/*/logs/

# Within logic, ignore transient data
/logic/test/*.pdf
!/logic/test/

# Root transient folders (ignored but NOT cleaned by sync)
/data/
/logs/
/tmp/
/resource/

# Python patterns
**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt

# System patterns
.DS_Store
Thumbs.db
