# --- Framework Core ---
/*
!/main.py
!/setup.py
!/tool.json
!/README.md
!/AGENT.md
!/AGENTS.md

# --- Framework Directories ---
!/logic/
!/interface/
!/test/
!/tool/
!/report/
/report/pdf/
!/skills/
!/migrate/

# --- Data Directory ---
# data/ is the canonical root for all user/runtime data.
# Everything inside is gitignored except explicitly tracked subdirs.
!/data/
/data/*
!/data/_/
/data/_/*
!/data/_/runtime/
!/data/_/workspace/

# --- Transient Directories (tool-level) ---
tool/**/data/
tool/**/logs/
tool/**/tmp/
**/logs/
**/tmp/

# --- Resource Management ---
# Install archives and resources are only on the remote tool branch.
/logic/_/dev/archived/
/logic/_/dev/resource/
**/resource/

# --- Python Patterns ---
**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt

# --- System Patterns ---
.DS_Store
Thumbs.db

# --- Tool Specific Rules ---
# 
!/bin/

# PYTHON
!/tool/PYTHON/
/tool/PYTHON/data/*
!/tool/PYTHON/data/install/
/tool/PYTHON/logs/

# VPN
!/tool/VPN/
/tool/VPN/data/
/tool/VPN/logs/

# iCloud.iCloudPD
/tool/iCloud.iCloudPD/data/
