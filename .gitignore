# --- Framework Core ---
/*
!/main.py
!/setup.py
!/tool.json
!/README.md
!/.gitignore
!/.gitattributes

# --- Framework Directories ---
!/logic/
!/bin/
!/test/
!/tool/
!/report/
!/resource/

# --- Transient Directories ---
**/data/
**/logs/
**/tmp/

# --- Resource Management ---
# Global ignore for resource dirs, negated for specific tools
**/resource/
!/resource/
!/resource/tool/PYTHON/
!/resource/tool/PYTHON/**/data/
!/resource/tool/GDS/
!/resource/tool/GOOGLE.GCS/

# --- Python Patterns ---
**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt

# --- System Patterns ---
.DS_Store
Thumbs.db

# --- Tool Specific Rules ---
# PYTHON
!/tool/PYTHON/
!/tool/PYTHON/data/
/tool/PYTHON/data/*
!/tool/PYTHON/data/install/
/tool/PYTHON/logs/

# VPN
!/tool/VPN/
/tool/VPN/data/
/tool/VPN/logs/

# iCloud / tool / iCloudPD
/tool/iCloud/tool/iCloudPD/data/
