                        "task_id": t["task_id"],
                        "files": [os.path.join(content_dir, f) for f in t["files"]],
                        "source_dir": content_dir,
                        "target_dir": target_root,
                        "fingerprint": f"{fingerprint_dir}/task_{t['task_id']:04d}_ok",
