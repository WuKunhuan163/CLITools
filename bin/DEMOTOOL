#!/usr/bin/env python3
import sys
import os
import subprocess
from pathlib import Path

# Add the directory containing 'logic' to PYTHONPATH for the subprocess
logicect_root = Path('/Applications/AITerminalTools')
python_tool_dir = logicect_root / "tool" / "PYTHON"

if not python_tool_dir.exists():
    from logic.utils import print_missing_tool_error
    print_missing_tool_error(tool_name, "PYTHON", tool_parent_dir / tool_name, _)
    sys.exit(1)

sys.path.append(str(python_tool_dir))

try:
    from logic.utils import get_python_exec
    python_exec = get_python_exec()
except ImportError:
    python_exec = "python3"

# Set up environment
env = os.environ.copy()
tool_main = Path('/Applications/AITerminalTools/tool/DEMOTOOL/main.py')
env["PYTHONPATH"] = f"{logicect_root}:{tool_main.parent}:{env.get('PYTHONPATH', '')}"

if __name__ == "__main__":
    result = subprocess.run([python_exec, str(tool_main)] + sys.argv[1:], env=env)
    sys.exit(result.returncode)
