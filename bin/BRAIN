#!/usr/bin/env python3
"""BRAIN — delegates to TOOL ---brain eco command.

BRAIN is ecosystem infrastructure, not a standalone tool.
All brain commands are available via: TOOL ---brain <command>
This script provides backward-compatible shorthand.
"""
import sys
from pathlib import Path

project_root = Path(__file__).resolve().parent.parent
if str(project_root) not in sys.path:
    sys.path.insert(0, str(project_root))

from logic._.brain.cli import BrainCommand

cmd = BrainCommand(project_root=project_root, tool_name="BRAIN")
args = sys.argv[1:]
sys.exit(cmd.handle(args) or 0)
