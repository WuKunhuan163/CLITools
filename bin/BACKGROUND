#!/usr/bin/env python3
import sys
import os
import subprocess
from pathlib import Path

# Add the directory containing 'logic' to PYTHONPATH for the subprocess
logicect_root = Path('/Applications/AITerminalTools')
python_tool_dir = logicect_root / "tool" / "PYTHON"
sys.path.append(str(python_tool_dir))

# Use system python3 for BACKGROUND tool as it needs psutil and other system-level deps
python_exec = "python3"

# Set up environment
env = os.environ.copy()
# Add the logicect root (containing root 'logic') and tool's directory (containing 'logic') to PYTHONPATH
tool_main = Path('/Applications/AITerminalTools/tool/BACKGROUND/main.py')
env["PYTHONPATH"] = f"{logicect_root}:{tool_main.parent}:{env.get('PYTHONPATH', '')}"

if __name__ == "__main__":
    import signal
    # Ignore SIGINT in the wrapper; the child process will handle it
    signal.signal(signal.SIGINT, signal.SIG_IGN)
    result = subprocess.run([python_exec, str(tool_main)] + sys.argv[1:], env=env)
    sys.exit(result.returncode)
